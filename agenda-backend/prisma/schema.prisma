// URL real de conexión se lee de DATABASE_URL (.env), no se escribe aquí.
datasource db {
  provider = "mysql"
}

generator client {
  provider = "prisma-client-js"
}

// Tabla de contactos de la agenda.
model Contacto {
  id      Int     @id @default(autoincrement())
  nombre  String
  telefono String
  correo  String
  etiqueta String
  empresa String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Tabla de usuarios (login).
model Usuario {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String // Hash de bcrypt, nunca texto plano.
  nombre   String

  createdAt DateTime @default(now())
}
